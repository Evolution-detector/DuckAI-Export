{
  "name": "duckai-export",
  "version": "1.0.0",
  "description": "Duck.ai 全量 Markdown 备份浏览器扩展 - 将对话数据导出为结构化 Markdown ZIP 包",
  "type": "module",
  "scripts": {
    "dev": "wxt dev -b firefox --mv3",
